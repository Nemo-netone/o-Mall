# 环境变量配置示例
# 真实值写到 .env（已被 .gitignore 忽略），不要提交。

# ── 数据库（Supabase = PostgreSQL）──
# 服务端迁移/seed 用的连接串（Supabase 控制台 → Database → Connection string，Session pooler）
# 形如：postgresql://postgres.<ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://localhost:5432/omall

# ── 前端（Vite 构建期注入，anon key 为公开值，由 RLS 保护）──
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# 可选：AI 回答代理地址。前端只写自己的后端/云函数 URL，不要写模型供应商密钥。
# 本地开发未配置时走 Vite /api 代理；生产未配置时使用本地商品库规则兜底。
# CloudBase 已配置 HTTP 云函数路由时，构建可设置：VITE_AI_PROXY_URL=/api/ai/chat
# VITE_AI_PROXY_URL=https://<your-api-domain>/api/ai/chat

# ── 后端 API 服务（仅服务端用）──
# 硅基流动 API Key（本地 Express 或 CloudBase HTTP 云函数环境变量；不要暴露到前端）
SILICONFLOW_API_KEY=sk-your-api-key-here

# ── 管理/迁移（仅本地脚本用，切勿提交、切勿进前端）──
# Personal Access Token（sbp_ 开头），用于 supabase CLI 与 Management API
# SUPABASE_ACCESS_TOKEN=sbp_xxx
# SUPABASE_PAT=sbp_xxx
# SUPABASE_PROJECT_REF=<project-ref>

# API 服务器端口
PORT=3000

# Node 环境
NODE_ENV=development
